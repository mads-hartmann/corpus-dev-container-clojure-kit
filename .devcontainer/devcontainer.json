{
	"name": "Clojure Kit Corpus App",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/java": {
			"version": "21",
			"installMaven": false,
			"installGradle": false
		}
	},
	"forwardPorts": [3000],
	"portsAttributes": {
		"3000": {
			"label": "Kit Server",
			"onAutoForward": "notify"
		}
	}
}
